# ──────────────────────────────────────────────────────────────────────────────
# Project Zenith — Environment Variables
# Copy this file to .env.local and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# CesiumJS Ion Access Token (REQUIRED for terrain + imagery)
# Sign up for a free token at: https://ion.cesium.com
# Without this, the globe will render a plain ellipsoid with no imagery.
NEXT_PUBLIC_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# Google Gemini API Key (used by Member B for AI sky descriptions)
# Get one at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
