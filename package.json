{
  "name": "astralweb",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node -e \"const fs = require('fs'); fs.rmSync('.next', {recursive:true,force:true})\" && next dev",
    "copy-cesium": "node scripts/copy-cesium-assets.mjs",
    "build": "node -e \"const fs = require('fs'); fs.rmSync('.next', {recursive:true,force:true})\" && npm run prepare-stars && npm run copy-cesium && next build",
    "start": "next start",
    "lint": "next lint",
    "prepare-stars": "npx tsx scripts/prepare_stars.ts",
    "postinstall": "node scripts/copy-cesium-assets.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^9.102.6",
    "@react-three/fiber": "^8.17.10",
    "@types/three": "^0.184.1",
    "astronomy-engine": "^2.1.19",
    "cesium": "^1.142.0",
    "color-string": "^2.1.4",
    "d3-color": "^3.1.0",
    "framer-motion": "^12.41.0",
    "next": "14.2.35",
    "papaparse": "^5.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "satellite.js": "^5.0.0",
    "three": "^0.184.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
